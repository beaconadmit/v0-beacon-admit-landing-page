# =============================================================================
# Production Environment Variables for beaconadmit.com
# Copy this file to .env.local for development or set in Vercel dashboard
# =============================================================================

# ---- Supabase (Database & Auth) ----
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_URL="https://your-project.supabase.co"

# ---- Retell AI (Voice Agent) ----
# Get from: https://retellai.com/dashboard
RETELL_API_KEY="your-retell-api-key"
RETELL_AGENT_ID="your-retell-agent-id"
RETELL_WEBHOOK_URL="https://beaconadmit.com/api/retell/webhook"

# ---- Resend (Email) ----
# Get from: https://resend.com/api-keys
RESEND_API_KEY="your-resend-api-key"

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="https://beaconadmit.com"

# ---- Vercel Analytics (auto-injected by Vercel) ----
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID (optional, Vercel injects automatically)
